body
  font-family Georgia, 'Times New Roman', Times, serif

h1,
h2,
h3,
h4,
h5,
h6
  font-weight 500
  text-transform uppercase
  font-style italic
  border 0

.sans-serif
  font-family Arial, Helvetica, sans-serif

.page
  background-color #c2eaba
  background-image linear-gradient(319deg, #c2eaba 0%, #c5f4e0 37%, #efc2cf 100%)
  padding-top 3.6rem

.content
  &__default
    background-color #fff
    min-height calc(100vh - 7.6rem)
    p
      max-width 50em

.navbar
  background-color #c2eaba
  background-image linear-gradient(319deg, #c2eaba 0%, #c5f4e0 37%, #efc2cf 100%)
  opacity 0.8
  width 100%
  max-width 820px
  margin 0 auto

.navbar .links, .search-box input
  background-color transparent !important

#name h1
    margin 0

.navbar .site-name
  text-transform uppercase
  font-weight normal
  font-style italic

.button
  display inline-block
  background-color #c2eaba
  padding 1em
  width auto
  &:hover
    background-color #efc2cf

.nav-link.external svg
  display none

.page
  padding-bottom 0 !important

.page-edit
  display none

.posts__post

  &:not(:first-child)
    border-top #000 1px solid